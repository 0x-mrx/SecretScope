# SecretScope Environment Configuration

# Security Settings
# Generate a secure secret key using: openssl rand -hex 32
SECRET_KEY=super-secret-jwt-signing-key-change-in-prod-1234!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database Settings
POSTGRES_USER=secretscope
POSTGRES_PASSWORD=SecretScopeSecurePassword123!
POSTGRES_DB=secretscope
DATABASE_URL=postgresql://secretscope:SecretScopeSecurePassword123!@postgres:5432/secretscope

# Caching & Background Jobs
REDIS_URL=redis://redis:6379/0

# Encryption at Rest (32-byte Fernet key base64 encoded)
# Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=uP2Nl6eE2K3jP-hE0k_g3rO_b5DqR9xK6eJ7Z1d3nK4=

# Storage Settings
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=/var/lib/secretscope/storage

# MinIO Settings (Only used if STORAGE_PROVIDER=minio)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=secretscope_admin
MINIO_SECRET_KEY=SecretScopeMinioSecurePassword123!
MINIO_SECURE=false
MINIO_BUCKET_NAME=secretscope-reports
